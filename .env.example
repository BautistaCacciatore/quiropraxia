# ==============================================================
#              VARIABLES DE ENTORNO — Quiropraxia
# ==============================================================
# Copiar como ".env" en la raíz del proyecto.
# NUNCA subir el .env real al repositorio.
# ==============================================================

# ──────────────────────────────────────────────────────────────
#  BASE DE DATOS (desarrollo local con Docker)
#  docker compose up -d levanta PostgreSQL con estas credenciales
# ──────────────────────────────────────────────────────────────
POSTGRES_DB=quiro_db
POSTGRES_USER=quiro_user
POSTGRES_PASSWORD=elegí_una_contraseña_segura
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ──────────────────────────────────────────────────────────────
#  BASE DE DATOS (producción en Supabase)
#  Tiene prioridad sobre las variables de arriba.
#  La obtainés de: Supabase > Project Settings > Database > URI
#  IMPORTANTE: reemplazar "postgresql://" por "postgresql+psycopg2://"
# ──────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+psycopg2://postgres:password@aws-0-region.supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────────
#  BACKEND (despliegue)
# ──────────────────────────────────────────────────────────────
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie segura: TRUE en producción (HTTPS), FALSE en local
COOKIE_SECURE=false

# Clave secreta para firmar tokens JWT
SECRET_KEY=cambiame-en-produccion-por-una-clave-segura

# ──────────────────────────────────────────────────────────────
#  OPCIONALES
# ──────────────────────────────────────────────────────────────
# SQL_ECHO=true   # si querés ver las consultas SQL en consola
# UPLOADS_DIR=uploads
