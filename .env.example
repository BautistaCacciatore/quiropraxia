# Único .env del proyecto. Lo usa tanto docker-compose.yml (para crear la
# base de datos) como el backend en Python (para conectarse a ella).
# Copiá este archivo como ".env" en la RAÍZ del proyecto.
# NUNCA lo subas real a un repositorio público.

POSTGRES_DB=quiro_db
POSTGRES_USER=quiro_user
POSTGRES_PASSWORD=elegí_una_contraseña_segura
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

SQL_ECHO=false
